APP_URL=http://localhost:3000
# Local development: Docker MySQL (npm run db:up). Production: Aiven defaultdb on Vercel.
DATABASE_URL=mysql://bookswap:bookswap@127.0.0.1:3307/bookswap_dev
DATABASE_DRIVER=mysql2
# Local Docker: false. Aiven: use DATABASE_URL with ?ssl-mode=REQUIRED (TLS auto-enabled).
DATABASE_SSL=false
# Aiven/managed MySQL: leave unset or set false. Only set true when you install the provider CA bundle.
DATABASE_SSL_REJECT_UNAUTHORIZED=false

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
OWNER_CLERK_USER_ID=
# Clerk Dashboard -> Webhooks -> add endpoint /api/webhooks/clerk -> Signing Secret
CLERK_WEBHOOK_SIGNING_SECRET=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

BLOB_READ_WRITE_TOKEN=
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_API_KEY=
# Use a dev-only index locally. Production should use bookswap_listings.
ALGOLIA_INDEX_NAME=bookswap_listings_dev
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=
ABLY_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=BookSwap <notifications@example.com>
SUPPORT_EMAIL=

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

NEXT_PUBLIC_MAINTENANCE_BANNER=
NEXT_PUBLIC_DEGRADED_BANNER=
RATE_LIMIT_BYPASS=false
ANONYMIZATION_RETENTION_DAYS=30
# Server-side secret for HMAC-SHA256 hashing of verified E.164 phone numbers (never store raw numbers).
PHONE_HMAC_KEY=
